{
  "name": "accounting-app",
  "version": "2.1.0",
  "description": "公司帳務管理系統",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:web": "node server.js",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.1.0",
    "express": "^4.18.0",
    "googleapis": "^140.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.fongyu.accounting",
    "productName": "帳務管理系統",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "fongyuteam",
      "repo": "accounting-app"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "帳務管理系統"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 380,
          "type": "file",
          "path": "scripts/install.command"
        }
      ]
    },
    "files": [
      "**/*",
      "!dist/**",
      "!*.md",
      "!server.js",
      "!google-auth-web.js",
      "!start.bat"
    ]
  }
}
